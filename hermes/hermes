#!/usr/bin/env bash

# Hermes AI Platform - Unified Command Line Interface (CLI)
# Targets: Ubuntu 24.04 LTS (x86_64)

set -o pipefail

# Color variables for styling
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Determine the absolute directory of this script, resolving symlinks if globally linked
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
HERMES_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

# Ensure all operations run in the Hermes directory context
cd "$HERMES_DIR"

show_help() {
    echo -e "${BLUE}====================================================${NC}"
    echo -e "${BLUE}         Hermes AI Platform Management CLI         ${NC}"
    echo -e "${BLUE}====================================================${NC}"
    echo -e "Usage: ${GREEN}hermes${NC} <command> [arguments]"
    echo ""
    echo -e "Available Commands:"
    echo -e "  ${GREEN}install${NC}           Initiate interactive platform installation"
    echo -e "  ${GREEN}doctor${NC}            Run pre-flight system diagnostics and health audit"
    echo -e "  ${GREEN}backup${NC}            Create compressed database and volume backup archives"
    echo -e "  ${GREEN}restore${NC} <file>    Restore database and volumes from a backup archive"
    echo -e "  ${GREEN}upgrade${NC}           Fetch updates and perform zero-downtime platform upgrade"
    echo -e "  ${GREEN}status${NC}            View current status of all platform services"
    echo -e "  ${GREEN}logs${NC} [service]    Stream container logs (defaults to all services)"
    echo -e "  ${GREEN}restart${NC} [service] Restart platform containers (defaults to all services)"
    echo -e "  ${GREEN}link${NC}              Register 'hermes' command globally in /usr/local/bin"
    echo -e "  ${GREEN}help, -h, --help${NC}  Display this management help menu"
    echo -e "${BLUE}====================================================${NC}"
}

link_globally() {
    echo -e "${YELLOW}Registering hermes CLI globally in /usr/local/bin/hermes...${NC}"
    if sudo ln -sf "$HERMES_DIR/hermes" /usr/local/bin/hermes; then
        echo -e "${GREEN}✓ Global CLI linked successfully! You can now run 'hermes' from any directory.${NC}"
    else
        echo -e "${RED}✗ Error: Failed to link globally. Please run as user with sudo privileges.${NC}" >&2
        exit 1
    fi
}

COMMAND=$1
shift || true

case "$COMMAND" in
    install)
        bash ./install.sh "$@"
        ;;
    doctor)
        bash ./doctor.sh "$@"
        ;;
    backup)
        bash ./backup.sh "$@"
        ;;
    restore)
        if [ -z "$1" ]; then
            echo -e "${RED}✗ Error: Backup archive path required.${NC}" >&2
            echo -e "Usage: ${YELLOW}hermes restore backups/hermes_backup_timestamp.tar.gz${NC}"
            exit 1
        fi
        bash ./restore.sh "$@"
        ;;
    upgrade)
        bash ./upgrade.sh "$@"
        ;;
    status)
        if [ ! -f docker-compose.yml ]; then
            echo -e "${RED}✗ Error: Platform configuration docker-compose.yml not found in $HERMES_DIR.${NC}" >&2
            exit 1
        fi
        docker compose ps
        ;;
    logs)
        if [ ! -f docker-compose.yml ]; then
            echo -e "${RED}✗ Error: Platform configuration docker-compose.yml not found in $HERMES_DIR.${NC}" >&2
            exit 1
        fi
        docker compose logs -f "$@"
        ;;
    restart)
        if [ ! -f docker-compose.yml ]; then
            echo -e "${RED}✗ Error: Platform configuration docker-compose.yml not found in $HERMES_DIR.${NC}" >&2
            exit 1
        fi
        echo -e "${YELLOW}Restarting services...${NC}"
        docker compose restart "$@"
        ;;
    link)
        link_globally
        ;;
    help|-h|--help|"")
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $COMMAND${NC}" >&2
        show_help
        exit 1
        ;;
esac
