APP_NAME=Hermes
APP_ENV=local
APP_KEY=base64:eXpSMjV3M3RkOTg3NnZjeDF5M3I1Njc4OWFiY2RlZmc=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=hermes
DB_USERNAME=hermes
DB_PASSWORD=hermes_secure_pass

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
CACHE_PREFIX=hermes_cache_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

QUEUE_CONNECTION=redis

# MinIO (S3 Compatible Storage)
AWS_ACCESS_KEY_ID=hermes_admin
AWS_SECRET_ACCESS_KEY=hermes_minio_pass
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=hermes-storage
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Qdrant Vector DB
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# LLM Providers (Pluggable)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_HOST=http://host.docker.internal:11434

# Voice API (Pluggable)
DEFAULT_VOICE_PROVIDER=elevenlabs
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=hermes_webhook_verification_token

# n8n
N8N_ENCRYPTION_KEY=hermes_n8n_secure_encryption_key
N8N_URL=http://localhost:5678

# Mail
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="admin@lspl.xyz"
MAIL_FROM_NAME="${APP_NAME}"

# Scout Search Engine (using database or database-alternative)
SCOUT_DRIVER=database
